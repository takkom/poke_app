# Local / OTA bundle API target.
# IMPORTANT: `eas update` inlines this into the JS bundle. For the v2-preview
# channel, this MUST stay on the v2 API or installs silently fall back to v1.
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
EXPO_PUBLIC_API_URL=https://xmon-api-v2-production.up.railway.app

# EAS native builds also pin API URL per profile in eas.json.