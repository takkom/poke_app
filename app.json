{
  "expo": {
    "name": "pokemon-tcg-app",
    "slug": "pokemon-tcg-app",
    "version": "0.2.8",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pokemontcgapp",
    "userInterfaceStyle": "automatic",
    "android": {
      "config": {
        "usesCleartextTraffic": true
      },
      "adaptiveIcon": {
        "backgroundColor": "#040404",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.takkom.pokemontcgapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#040404",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 280
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ef2c3d75-b5b6-44ea-b1a6-cd92833c8e38"
      }
    },
    "runtimeVersion": "1",
    "updates": {
      "url": "https://u.expo.dev/ef2c3d75-b5b6-44ea-b1a6-cd92833c8e38"
    }
  }
}
